import { Module } from '@nestjs/common';
import { ClientsModule, Transport } from '@nestjs/microservices';
import { {{pascalCase serviceName}}Controller } from './{{serviceName}}.controller';
import { {{pascalCase serviceName}}Service } from './{{serviceName}}.service';

@Module({
  imports: [
    ClientsModule.register([
      {
        name: '{{snakeCase serviceName}}_SERVICE'.toUpperCase(),
{{#if (eq transport "kafka")}}
        transport: Transport.KAFKA,
        options: {
          client: {
            clientId: '{{serviceName}}',
            brokers: [process.env.KAFKA_BROKER || 'localhost:9092'],
          },
          consumer: {
            groupId: '{{serviceName}}-consumer',
          },
        },
{{/if}}
{{#if (eq transport "rabbitmq")}}
        transport: Transport.RMQ,
        options: {
          urls: [process.env.RABBITMQ_URL || 'amqp://localhost:5672'],
          queue: '{{serviceName}}_queue',
          queueOptions: { durable: true },
        },
{{/if}}
{{#if (eq transport "redis")}}
        transport: Transport.REDIS,
        options: {
          host: process.env.REDIS_HOST || 'localhost',
          port: parseInt(process.env.REDIS_PORT || '6379'),
        },
{{/if}}
      },
    ]),
  ],
  controllers: [{{pascalCase serviceName}}Controller],
  providers: [{{pascalCase serviceName}}Service],
})
export class {{pascalCase serviceName}}Module {}
