name: CI — {{projectName}}

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

{{#if (eq runtime "node")}}
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '{{nodeVersion}}'
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Build
        run: npm run build
{{/if}}

{{#if (eq runtime "bun")}}
      - name: Setup Bun
        uses: oven-sh/setup-bun@v1

      - name: Install dependencies
        run: bun install

      - name: Build
        run: bun run build
{{/if}}

{{#if runTests}}
      - name: Run tests
{{#if (eq runtime "node")}}
        run: npm test
{{/if}}
{{#if (eq runtime "bun")}}
        run: bun test
{{/if}}
{{/if}}

{{#if docker}}
  docker:
    runs-on: ubuntu-latest
    needs: build

    steps:
      - uses: actions/checkout@v4

      - name: Login to Docker Hub
        uses: docker/login-action@v3
        with:
          username: $\{{secrets.DOCKER_USERNAME}}
          password: $\{{secrets.DOCKER_PASSWORD}}

      - name: Build and push
        uses: docker/build-push-action@v5
        with:
          push: true
          tags: $\{{secrets.DOCKER_USERNAME}}/{{projectName}}:latest
{{/if}}
